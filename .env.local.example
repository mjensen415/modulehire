# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron
# Shared secret guarding /api/cron/purge. Vercel Cron sends it as
# "Authorization: Bearer <CRON_SECRET>". Set the real value in Vercel env vars.
CRON_SECRET=

# ─── Stripe (ModuleHire 1.0) ──────────────────────────────────────────────
# Create these products in the Stripe dashboard, then paste the price IDs below.
# Products:
#   - Single resume     — $9 one-time          → STRIPE_PRICE_SINGLE_RESUME
#   - 5-pack            — $29 one-time         → STRIPE_PRICE_FIVE_PACK
#   - Pro Monthly       — $19/mo recurring     → STRIPE_PRICE_PRO_MONTHLY
#   - Pro Annual        — $99/yr recurring     → STRIPE_PRICE_PRO_ANNUAL
# Portal config: create a Customer Portal configuration in the dashboard
# (Settings → Billing → Customer portal) and paste its ID into STRIPE_PORTAL_CONFIG_ID.

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PORTAL_CONFIG_ID=

STRIPE_PRICE_SINGLE_RESUME=
STRIPE_PRICE_FIVE_PACK=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_ANNUAL=
